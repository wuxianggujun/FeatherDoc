{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/featherdoc/pdf_regression_manifest.schema.json",
  "title": "FeatherDoc PDF Regression Manifest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sample"
      }
    }
  },
  "required": [
    "samples"
  ],
  "$defs": {
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "output_file": {
          "type": "string",
          "minLength": 1
        },
        "expected_pages": {
          "type": "integer",
          "minimum": 1
        },
        "expected_text": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "expected_image_count": {
          "type": "integer",
          "minimum": 1
        },
        "expect_unicode": {
          "type": "boolean"
        },
        "expect_styled_text": {
          "type": "boolean"
        },
        "expect_cjk": {
          "type": "boolean"
        },
        "expect_visual_baseline": {
          "type": "boolean"
        },
        "visual_expected_pages": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "id",
        "kind",
        "output_file",
        "expected_pages",
        "expected_text"
      ]
    }
  }
}
