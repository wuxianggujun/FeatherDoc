{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/featherdoc/project_template_smoke.manifest.schema.json",
  "title": "FeatherDoc Project Template Smoke Manifest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/entry"
      }
    },
    "business_template_corpus": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/businessTemplateCorpusItem"
      }
    },
    "candidate_exclusions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidateExclusion"
      }
    }
  },
  "required": [
    "entries"
  ],
  "$defs": {
    "slotString": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[^:]+:[^:]+"
    },
    "slotObject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bookmark": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        },
        "optional": {
          "type": "boolean"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "min": {
          "type": "integer",
          "minimum": 0
        },
        "max": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "kind"
      ],
      "anyOf": [
        {
          "required": [
            "bookmark"
          ]
        },
        {
          "required": [
            "name"
          ]
        }
      ]
    },
    "slotSpec": {
      "oneOf": [
        {
          "$ref": "#/$defs/slotString"
        },
        {
          "$ref": "#/$defs/slotObject"
        }
      ]
    },
    "selectionBase": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "part": {
          "type": "string",
          "enum": [
            "body",
            "header",
            "footer",
            "section-header",
            "section-footer"
          ]
        },
        "index": {
          "type": "integer",
          "minimum": 0
        },
        "section": {
          "type": "integer",
          "minimum": 0
        },
        "kind": {
          "type": "string",
          "enum": [
            "default",
            "first",
            "even"
          ]
        },
        "slots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/slotSpec"
          }
        }
      },
      "required": [
        "part"
      ]
    },
    "schemaValidation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_file": {
          "type": "string",
          "minLength": 1
        },
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/selectionBase"
          }
        }
      }
    },
    "schemaBaseline": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_file": {
          "type": "string",
          "minLength": 1
        },
        "target_mode": {
          "type": "string",
          "enum": [
            "default",
            "section-targets",
            "resolved-section-targets"
          ]
        },
        "generated_output": {
          "type": "string",
          "minLength": 1
        },
        "repaired_output": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "schema_file"
      ]
    },
    "visualSmokeObject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "input": {
          "type": "string",
          "enum": [
            "template",
            "rendered_docx"
          ]
        },
        "output_dir": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "renderDataSmoke": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "data_path": {
          "type": "string",
          "minLength": 1
        },
        "mapping_path": {
          "type": "string",
          "minLength": 1
        },
        "output_docx": {
          "type": "string",
          "minLength": 1
        },
        "summary_json": {
          "type": "string",
          "minLength": 1
        },
        "patch_plan_output": {
          "type": "string",
          "minLength": 1
        },
        "draft_plan_output": {
          "type": "string",
          "minLength": 1
        },
        "patched_plan_output": {
          "type": "string",
          "minLength": 1
        },
        "export_target_mode": {
          "type": "string",
          "enum": [
            "loaded-parts",
            "resolved-section-targets"
          ]
        }
      },
      "required": [
        "data_path",
        "mapping_path"
      ]
    },
    "candidateExclusion": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "path",
        "reason"
      ]
    },
    "businessTemplateCorpusItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "template_name": {
          "type": "string",
          "minLength": 1
        },
        "document_type": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "registered",
            "planned"
          ]
        },
        "source_entry": {
          "type": "string",
          "minLength": 1
        },
        "smoke_contract": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "coverage_goal": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "id",
        "project_id",
        "template_name",
        "document_type",
        "status",
        "smoke_contract",
        "coverage_goal"
      ]
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "project_id": {
          "type": "string",
          "minLength": 1
        },
        "template_name": {
          "type": "string",
          "minLength": 1
        },
        "business_domain": {
          "type": "string",
          "minLength": 1
        },
        "business_document_type": {
          "type": "string",
          "minLength": 1
        },
        "corpus_role": {
          "type": "string",
          "minLength": 1
        },
        "corpus_source_note": {
          "type": "string",
          "minLength": 1
        },
        "input_docx": {
          "type": "string",
          "minLength": 1
        },
        "input_docx_build_relative": {
          "type": "string",
          "minLength": 1
        },
        "prepare_sample_target": {
          "type": "string",
          "minLength": 1
        },
        "prepare_argument": {
          "type": "string",
          "minLength": 1
        },
        "template_validations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/selectionBase"
          }
        },
        "schema_validation": {
          "$ref": "#/$defs/schemaValidation"
        },
        "schema_baseline": {
          "$ref": "#/$defs/schemaBaseline"
        },
        "render_data_smoke": {
          "$ref": "#/$defs/renderDataSmoke"
        },
        "visual_smoke": {
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "$ref": "#/$defs/visualSmokeObject"
            }
          ]
        }
      },
      "required": [
        "name"
      ],
      "anyOf": [
        {
          "required": [
            "input_docx"
          ]
        },
        {
          "required": [
            "input_docx_build_relative"
          ]
        }
      ]
    }
  }
}
